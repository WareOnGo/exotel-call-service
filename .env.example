# ---- HTTP ----
PORT=8080

# ---- Supabase Postgres (use the DIRECT connection string, port 5432) ----
# Dashboard → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# ---- Exotel ----
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=your_account_sid
EXOTEL_SUBDOMAIN=api.exotel.com
# ExoPhone shown as caller id for click-to-call when not specified per request.
DEFAULT_CALLER_ID=

# ---- Routing ----
# Dialed when the router can't resolve a contact (DB slow/down, none configured).
DEFAULT_FALLBACK_NUMBER=
# Hard cap on the assignment lookup on the hot path (ms).
ROUTER_DB_TIMEOUT_MS=150

# ---- Reconcile (history sync backstop) ----
SYNC_INTERVAL_MIN=15
SYNC_LOOKBACK_MIN=90
# Shared secret required in the X-Sync-Secret header to trigger POST /sync
# and POST /archive-recordings.
SYNC_SECRET=

# ---- Cloudflare R2 recording archive (optional; archive disabled if unset) ----
# Either set R2_ENDPOINT directly, or just R2_ACCOUNT_ID to derive it.
R2_ACCOUNT_ID=
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_KEY_PREFIX=recordings
ARCHIVE_INTERVAL_HOURS=24
ARCHIVE_BATCH_SIZE=200
ARCHIVE_MAX_ATTEMPTS=5
ARCHIVE_WORKERS=4
